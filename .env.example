# 本地開發不需要任何環境變數（會用 sqlite:///./gym.db）
# 部署時可設：

# Postgres 連線字串（例：Neon 會給這串，含 sslmode=require）
# DATABASE_URL=postgresql://user:pass@host/dbname?sslmode=require

# 前端網域白名單（逗號分隔），未設則預設開放所有來源
# ALLOWED_ORIGINS=https://your-domain.onrender.com

# HTTP Basic Auth（都設才會生效；兩者任一為空則完全不擋，給本地開發用）
# GYM_USERNAME=yourname
# GYM_PASSWORD=long-random-string

# 跳過啟動時的預設動作 seed（主要給測試用）
# GYM_SKIP_SEED=1
